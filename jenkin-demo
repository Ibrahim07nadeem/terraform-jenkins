pipeline {
    agent any

    tools {
        terraform 'terraform'
    }

    stages {

        stage('Terraform Init') {
            steps {
                dir('jenkin-demo') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('jenkin-demo') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('jenkin-demo') {
                    sh 'terraform plan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('jenkin-demo') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }
    }
}
